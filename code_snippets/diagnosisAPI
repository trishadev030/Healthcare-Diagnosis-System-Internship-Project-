                  : <MaterialCommunityIcons name="pencil-outline" size={16} color="#667eea" />
                }
                <Text style={styles.editButtonText}>{isEditLoading ? 'Loading...' : 'Edit'}</Text>
              </TouchableOpacity>

              {diagnosis.diagnosisType?.toLowerCase() !== 'principle' && (
                <TouchableOpacity
                  style={[styles.deleteButton, isDeleteLoading && { opacity: 0.6 }]}
                  onPress={() => onDelete(diagnosis.encryptedID)}
                  disabled={isDeleteLoading}
                >
                  {isDeleteLoading
                    ? <ActivityIndicator size="small" color="#dc2626" />
                    : <MaterialCommunityIcons name="trash-can-outline" size={16} color="#dc2626" />
                  }
