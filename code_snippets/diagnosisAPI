export const DiagnosisTab = forwardRef<DiagnosisTabHandle, DiagnosisTabProps>((
  { patient, onAddDiagnosis, onOpenEditDiagnosis, refreshKey = 0, onDiagnosisCountChange },
  ref
) => {
  const [diagnoses, setDiagnoses]           = useState<Diagnosis[]>([]);
  const [loading, setLoading]               = useState(false);
  const [editLoading, setEditLoading]       = useState<string | null>(null);
  const [deleteLoading, setDeleteLoading]   = useState<string | null>(null);
  const [saveLoading, setSaveLoading]       = useState(false);
  const [activeTabLocal, setActiveTabLocal] = useState<'manage' | 'add'>('manage');
  const [filterType, setFilterType]         = useState<string | null>(null);
  const [showFilter, setShowFilter]         = useState(false);
  const [isFirstDiagnosis, setIsFirstDiagnosis] = useState(false);

  const [selectMode, setSelectMode]     = useState(false);
  const [selectedIDs, setSelectedIDs]   = useState<string[]>([]);
  const [selectAll, setSelectAll]       = useState(false);
  const [insightPopup, setInsightPopup] = useState<{ diagnoses: Diagnosis[]; text: string } | null>(null);
  const [aiLoading, setAiLoading]       = useState(false);

  const [showNoDiagnosisPopup, setShowNoDiagnosisPopup] = useState(false);
  const [showAssignedPopup, setShowAssignedPopup]       = useState(false);
  const [assignedPopupInfo, setAssignedPopupInfo]       = useState<{ isEdit: boolean } | null>(null);
  const [showDeleteConfirmPopup, setShowDeleteConfirmPopup] = useState(false);
  const [pendingDeleteID, setPendingDeleteID]               = useState<string | null>(null);
  const [showDeleteSuccessPopup, setShowDeleteSuccessPopup] = useState(false);

  const noDiagnosisAlertShown = useRef(false);
  const abortControllerRef    = useRef<AbortController | null>(null);

  const filteredDiagnoses = filterType
    ? diagnoses.filter(d => d.diagnosisType?.toLowerCase() === filterType.toLowerCase())
    : diagnoses;

  useImperativeHandle(ref, () => ({
    handleDiagnosisSaved: (savedData?: { isEdit?: boolean }) => {
      setActiveTabLocal('manage');
      setShowDeleteSuccessPopup(false);
      setShowDeleteConfirmPopup(false);
      setAssignedPopupInfo({ isEdit: savedData?.isEdit ?? false });
      setShowAssignedPopup(true);
    },
    switchToManage: () => setActiveTabLocal('manage'),
  }));

  useEffect(() => {
    if (filteredDiagnoses.length > 0 && selectedIDs.length === filteredDiagnoses.length) {
      setSelectAll(true);
    } else {
      setSelectAll(false);
    }
  }, [selectedIDs, filteredDiagnoses]);

  useEffect(() => {
    const load = async () => {
      setShowDeleteSuccessPopup(false);
      setShowDeleteConfirmPopup(false);

      if (!patient.participantID) {
        setDiagnoses([]);
        setIsFirstDiagnosis(false);
        onDiagnosisCountChange?.(0);
        setLoading(false);
        return;
      }
      setLoading(true);
      try {
        const data = await manageDiagnosisDetails(patient.participantID);
        const sorted = data
          ? [...data].sort((a: any, b: any) =>
              parseDate(b.lastModifiedDate || b.date) - parseDate(a.lastModifiedDate || a.date)
            )
          : [];
        setDiagnoses(sorted);
        onDiagnosisCountChange?.(sorted.length);

        if (sorted.length === 0) {
          setIsFirstDiagnosis(true);
          if (!noDiagnosisAlertShown.current) {
            noDiagnosisAlertShown.current = true;
            setActiveTabLocal('add');
            setShowNoDiagnosisPopup(true);
          }
        } else {
          setIsFirstDiagnosis(false);
        }
      } catch (err: any) {
        if (err.message?.includes('404') || err.status === 404) {
          setDiagnoses([]);
          setIsFirstDiagnosis(true);
          onDiagnosisCountChange?.(0);
          if (!noDiagnosisAlertShown.current) {
            noDiagnosisAlertShown.current = true;
            setActiveTabLocal('add');
            setShowNoDiagnosisPopup(true);
          }
        } else {
          Alert.alert("Error", err.message);
        }
      } finally {
        setLoading(false);
      }
    };
    load();
  }, [patient.participantID, refreshKey]);

  const handleEdit = async (encryptedID: string) => {
    setEditLoading(encryptedID);
    try {
      const details = await editDiagnosis(encryptedID);
      onOpenEditDiagnosis(details);
    } catch (err: any) {
      Alert.alert("Error", err.message);
    } finally {
      setEditLoading(null);
    }
  };

  const handleDelete = (encryptedID: string) => {
    setPendingDeleteID(encryptedID);
    setShowDeleteConfirmPopup(true);
  };

  const handleConfirmDelete = async () => {
    if (!pendingDeleteID) return;
    setShowDeleteConfirmPopup(false);
    setDeleteLoading(pendingDeleteID);
    try {
      await deleteDiagnosis(pendingDeleteID);
      setDiagnoses(prev => {
        const updated = prev.filter(d => d.encryptedID !== pendingDeleteID);
        onDiagnosisCountChange?.(updated.length);
        if (updated.length === 0) setIsFirstDiagnosis(true);
        return updated;
      });
      setShowDeleteSuccessPopup(true);
    } catch (err: any) {
      Alert.alert("Error", err.message);
    } finally {
      setDeleteLoading(null);
      setPendingDeleteID(null);
    }
  };

  const handleToggleSelect = (encryptedID: string) => {
    setSelectedIDs(prev =>
      prev.includes(encryptedID)
        ? prev.filter(id => id !== encryptedID)
        : [...prev, encryptedID]
    );
  };

  const handleAIIconPress = () => {
    setSelectMode(true);
    setSelectAll(false);
    setSelectedIDs(diagnoses.length > 0 ? [diagnoses[0].encryptedID] : []);
  };

  const handleCancelSelect = () => {
    setSelectMode(false);
    setSelectedIDs([]);
    setSelectAll(false);
  };

  const handleSelectAll = () => {
    if (selectAll) {
      setSelectedIDs([]);
      setSelectAll(false);
    } else {
      setSelectedIDs(filteredDiagnoses.map(d => d.encryptedID));
      setSelectAll(true);
    }
  };

  const fetchWithRetry = async (url: string, options: RequestInit, retries = 3, delay = 4000): Promise<Response> => {
    for (let i = 0; i < retries; i++) {
      const response = await fetch(url, options);
      if (response.ok) return response;
      if (response.status === 503 && i < retries - 1) {
        await new Promise<void>(res => setTimeout(() => res(), delay));
        continue;
      }
      throw new Error(`AI error: ${response.status}`);
    }
    throw new Error('Max retries reached');
  };

  const handleGenerateInsights = async () => {
    if (selectedIDs.length === 0) {
      Alert.alert("Select Diagnosis", "Please select at least one diagnosis.");
      return;
    }
    abortControllerRef.current?.abort();
    abortControllerRef.current = new AbortController();
    const selected = diagnoses.filter(d => selectedIDs.includes(d.encryptedID));
    setInsightPopup({ diagnoses: selected, text: '' });
    setAiLoading(true);
    try {
      const aiResponse = await fetchWithRetry(`${AI_BASE_URL}ai/insights`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        signal: abortControllerRef.current.signal,
        body: JSON.stringify({
          requestType:   "Insights for wellness",
          diagnosisCode: selected.map(d => d.icD10Code).join(', '),
          category:      selected.map(d => d.category).join(', '),
          description:   selected.map((d, i) => `${i + 1}. ${d.category}: ${d.description}`).join('\n'),
          userDiagnosis: selected.map(d => d.userDiagnosis).filter(Boolean).join(', '),
        }),
      });
      const aiData = await aiResponse.json();
      const insightText = cleanText(
        aiData.insight ?? aiData.content ?? aiData.data ?? aiData.result ?? ""
      );
      setInsightPopup({ diagnoses: selected, text: insightText });
    } catch (err: any) {
      if (err.name === 'AbortError') return;
      setInsightPopup(null);
      Alert.alert("AI Error", err.message || "Failed to generate insight");
    } finally {
      setAiLoading(false);
    }
  };

  const handleRegenerateInsight = async () => {
    if (!insightPopup) return;
    abortControllerRef.current?.abort();
    abortControllerRef.current = new AbortController();
    setAiLoading(true);
    try {
      const selected = insightPopup.diagnoses;
      const aiResponse = await fetchWithRetry(`${AI_BASE_URL}ai/insights`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        signal: abortControllerRef.current.signal,
        body: JSON.stringify({
          requestType:   "Insights for wellness",
          diagnosisCode: selected.map(d => d.icD10Code).join(', '),
          category:      selected.map(d => d.category).join(', '),
          description:   selected.map((d, i) => `${i + 1}. ${d.category}: ${d.description}`).join('\n'),
          userDiagnosis: selected.map(d => d.userDiagnosis).filter(Boolean).join(', '),
        }),
      });
      const aiData = await aiResponse.json();
      const insightText = cleanText(
        aiData.insight ?? aiData.content ?? aiData.data ?? aiData.result ?? ""
      );
      setInsightPopup(prev => prev ? { ...prev, text: insightText } : null);
    } catch (err: any) {
      if (err.name === 'AbortError') return;
      Alert.alert("AI Error", err.message || "Failed to regenerate");
    } finally {
      setAiLoading(false);
    }
  };

  const handleSaveInsight = async (saveToAll: boolean) => {
    if (!insightPopup) return;
    setSaveLoading(true);
    try {
      const diagnosesToSave = saveToAll ? insightPopup.diagnoses : [insightPopup.diagnoses[0]];

      await Promise.all(
        diagnosesToSave.map(d =>
          updateDiagnosisDetails({
            encrypteddiagnosisrecordID: d.encryptedID,
            readingDate:   d.date,
            ICDCode:       d.icD10Code,
            Category:      d.category,
            Description:   d.description,
            type:          DIAGNOSIS_TYPE_MAP[d.diagnosisType?.toLowerCase()] ?? '0',
            AIInsight:     insightPopup.text,
            UserDiagnosis: (d.userDiagnosis || '').trim(),
          })
        )
      );

      const insightText = insightPopup.text;
      const updatedIDs  = diagnosesToSave.map(d => d.encryptedID);
      const today       = new Date();
      const todayStr    = `${today.getMonth() + 1}/${today.getDate()}/${today.getFullYear()}`;

      setDiagnoses(prev => {
        const updated = prev.map(d =>
          updatedIDs.includes(d.encryptedID)
            ? { ...d, aiInsight: insightText, lastModifiedDate: todayStr }
            : d
        );
        return [...updated].sort((a, b) =>
          parseDate(b.lastModifiedDate || b.date) - parseDate(a.lastModifiedDate || a.date)
        );
      });

      setInsightPopup(null);
      setSelectMode(false);
      setSelectedIDs([]);
      setSelectAll(false);
    } catch (err: any) {
      Alert.alert("Save Error", err.message || "Failed to save insight");
    } finally {
      setSaveLoading(false);
    }
  };

  const handleCloseInsightPopup = () => {
    abortControllerRef.current?.abort();
    setInsightPopup(null);
    setAiLoading(false);
  };

  return (
    <View style={styles.diagnosisContainer}>
      <UnderDevelopmentOverlay />

      <View style={styles.stickyHeader}>
        <View style={styles.tabHeader}>
          <TouchableOpacity
            style={[styles.tabButton, activeTabLocal === 'manage' && styles.tabButtonActive]}
            onPress={() => {
              setActiveTabLocal('manage');
              setSelectMode(false);
              setSelectedIDs([]);
              setSelectAll(false);
            }}
          >
            <Text style={[styles.tabButtonText, activeTabLocal === 'manage' && styles.tabButtonTextActive]}>Manage</Text>
          </TouchableOpacity>
          <TouchableOpacity
            style={[styles.tabButton, activeTabLocal === 'add' && styles.tabButtonActive]}
            onPress={() => {
              setActiveTabLocal('add');
              setSelectMode(false);
              setSelectedIDs([]);
              setSelectAll(false);
              onAddDiagnosis(isFirstDiagnosis);
            }}
          >
            <Text style={[styles.tabButtonText, activeTabLocal === 'add' && styles.tabButtonTextActive]}>Add</Text>
          </TouchableOpacity>
        </View>

        {activeTabLocal === 'manage' && (
          <View style={styles.filterRow}>
            <TouchableOpacity
              style={[styles.filterIconBtn, !!filterType && styles.filterIconBtnActive]}
              onPress={() => setShowFilter(p => !p)}
            >
              <MaterialCommunityIcons name="filter-variant" size={14} color={!!filterType ? '#fff' : '#667eea'} />
              <Text style={[styles.filterIconText, !!filterType && styles.filterIconTextActive]}>{filterType ?? 'Filter'}</Text>
              <MaterialCommunityIcons name={showFilter ? "chevron-up" : "chevron-down"} size={13} color={!!filterType ? '#fff' : '#667eea'} />
            </TouchableOpacity>

            <View style={{ flex: 1 }} />

            {!selectMode ? (
              <TouchableOpacity style={styles.aiHeaderBtn} onPress={handleAIIconPress}>
                <MaterialCommunityIcons name="lightbulb-outline" size={16} color="#0891b2" />
                <Text style={styles.aiHeaderBtnText}>Insights</Text>
              </TouchableOpacity>
            ) : (
              <View style={{ flexDirection: 'row', gap: 8 }}>
                {selectedIDs.length >= 1 && (
                  <TouchableOpacity
                    style={[styles.aiHeaderBtn, styles.aiHeaderBtnActive, aiLoading && { opacity: 0.7 }]}
                    onPress={handleGenerateInsights}
                    disabled={aiLoading}
                  >
                    {aiLoading
                      ? <ActivityIndicator size="small" color="#fff" />
                      : <MaterialCommunityIcons name="lightbulb-on-outline" size={16} color="#fff" />
                    }
                    <Text style={[styles.aiHeaderBtnText, { color: '#fff' }]}>
                      {aiLoading ? 'Generating...' : `Generate (${selectedIDs.length})`}
                    </Text>
                  </TouchableOpacity>
                )}
                <TouchableOpacity style={[styles.aiHeaderBtn, styles.cancelSelectBtn]} onPress={handleCancelSelect}>
                  <MaterialCommunityIcons name="close" size={14} color="#fff" />
                  <Text style={[styles.aiHeaderBtnText, { color: '#fff' }]}>Cancel</Text>
                </TouchableOpacity>
              </View>
            )}
          </View>
        )}

        {activeTabLocal === 'manage' && showFilter && (
          <View style={styles.filterDropdown}>
            {FILTER_TYPES.map(type => (
              <TouchableOpacity
                key={type}
                style={[styles.filterDropdownItem, filterType === type && styles.filterDropdownItemActive]}
                onPress={() => {
                  setFilterType(prev => prev === type ? null : type);
                  setShowFilter(false);
                }}
              >
                <MaterialCommunityIcons name={getDiagnosisIcon(type)} size={14} color={filterType === type ? '#fff' : '#667eea'} />
                <Text style={[styles.filterDropdownItemText, filterType === type && styles.filterDropdownItemTextActive]}>{type}</Text>
                {filterType === type && (
                  <View style={{ marginLeft: 'auto' as any }}>
                    <MaterialCommunityIcons name="check" size={13} color="#fff" />
                  </View>
                )}
              </TouchableOpacity>
            ))}
            {filterType && (
              <TouchableOpacity style={styles.filterClearBtn} onPress={() => { setFilterType(null); setShowFilter(false); }}>
                <Text style={styles.filterClearText}>Clear filter</Text>
              </TouchableOpacity>
            )}
          </View>
        )}

        {selectMode && activeTabLocal === 'manage' && (
          <View style={styles.selectHintRow}>
            <Text style={styles.selectHint}>
              Tap cards to select • {selectedIDs.length} selected{selectAll ? ' (all)' : ''}
            </Text>
            <TouchableOpacity onPress={handleSelectAll} style={[styles.selectAllBtn, selectAll && styles.selectAllBtnActive]}>
              <MaterialCommunityIcons
                name={selectAll ? "checkbox-multiple-marked-outline" : "checkbox-multiple-blank-outline"}
                size={14}
                color={selectAll ? '#667eea' : '#9ca3af'}
              />
              <Text style={[styles.selectAllText, selectAll && styles.selectAllTextActive]}>
                {selectAll ? 'Deselect all' : 'Select all'}
              </Text>
            </TouchableOpacity>
          </View>
        )}
      </View>

      <ScrollView style={styles.scrollArea} contentContainerStyle={styles.scrollContent} showsVerticalScrollIndicator={false}>
        {activeTabLocal === 'manage' ? (
          <>
            {loading && <ActivityIndicator size="large" color="#667eea" style={{ marginVertical: 20 }} />}
            {filteredDiagnoses.map((diagnosis) => (
              <DiagnosisCard
                key={diagnosis.encryptedID}
                diagnosis={diagnosis}
                onEdit={handleEdit}
                onDelete={handleDelete}
                editLoading={editLoading}
                deleteLoading={deleteLoading}
                selectMode={selectMode}
                isSelected={selectedIDs.includes(diagnosis.encryptedID)}
                onToggleSelect={handleToggleSelect}
              />
            ))}
            {filteredDiagnoses.length === 0 && !loading && filterType && (
              <View style={styles.emptyFilter}>
                <MaterialCommunityIcons name="filter-off-outline" size={36} color="#d1d5db" />
                <Text style={styles.emptyFilterText}>No {filterType} diagnoses found</Text>
              </View>
            )}
          </>
        ) : (
          <AddDiagnosisButton onPress={() => onAddDiagnosis(isFirstDiagnosis)} />
        )}
      </ScrollView>

      {/* ── No Diagnosis Popup ── */}
      <Modal visible={showNoDiagnosisPopup} transparent animationType="fade" onRequestClose={() => setShowNoDiagnosisPopup(false)}>
        <View style={styles.popupOverlay}>
          <View style={styles.popupCard}>
            <TouchableOpacity
              style={styles.popupCloseBtn}
              onPress={() => setShowNoDiagnosisPopup(false)}
              hitSlop={{ top: 10, bottom: 10, left: 10, right: 10 }}
            >
              <MaterialCommunityIcons name="close" size={18} color="#9ca3af" />
            </TouchableOpacity>

            <View style={styles.popupIconRow}>
              <View style={[styles.popupIconCircle, { backgroundColor: '#eef2ff' }]}>
                <MaterialCommunityIcons name="clipboard-text-off-outline" size={22} color="#667eea" />
              </View>
            </View>

            <Text style={styles.popupTitle}>No Diagnosis Found</Text>
            <Text style={styles.popupBody}>
              A <Text style={{ fontWeight: '700', color: '#07143b' }}>Principle Diagnosis</Text> must be added before any other diagnoses.
            </Text>

            <View style={styles.popupDivider} />

            <View style={styles.popupBtnRow}>
              <TouchableOpacity
                style={styles.popupPrimaryBtn}
                onPress={() => {
                  setShowNoDiagnosisPopup(false);
                  setActiveTabLocal('add');
                  onAddDiagnosis(true);
                }}
              >
                <Text style={styles.popupPrimaryBtnText}>Add Principle Diagnosis</Text>
              </TouchableOpacity>
            </View>
          </View>
        </View>
      </Modal>

      {/* ── Diagnosis Added / Updated Popup ── */}
      <Modal visible={showAssignedPopup} transparent animationType="fade" onRequestClose={() => setShowAssignedPopup(false)}>
        <View style={styles.popupOverlay}>
          <View style={styles.popupCard}>
            <View style={styles.popupIconRow}>
              <View style={[styles.popupIconCircle, { backgroundColor: assignedPopupInfo?.isEdit ? '#eff6ff' : '#f0fdf4' }]}>
                <MaterialCommunityIcons
                  name={assignedPopupInfo?.isEdit ? 'pencil-outline' : 'check'}
                  size={22}
                  color={assignedPopupInfo?.isEdit ? '#3b82f6' : '#7DBE8E'}
                />
              </View>
            </View>
            <Text style={styles.popupTitle}>
              {assignedPopupInfo?.isEdit ? 'Diagnosis Updated' : 'Diagnosis Added'}
            </Text>
            <Text style={styles.popupBody}>
              {assignedPopupInfo?.isEdit
                ? 'The diagnosis has been successfully updated.'
                : 'The diagnosis has been successfully added.'}
            </Text>
            <View style={styles.popupDivider} />
            <View style={styles.popupBtnRow}>
              <TouchableOpacity
                style={[styles.popupPrimaryBtn, { backgroundColor: assignedPopupInfo?.isEdit ? '#3b82f6' : '#7DBE8E' }]}
                onPress={() => setShowAssignedPopup(false)}
              >
                <Text style={styles.popupPrimaryBtnText}>Done</Text>
              </TouchableOpacity>
            </View>
          </View>
        </View>
      </Modal>

      {/* ── Delete Confirm Popup ── */}
      <Modal visible={showDeleteConfirmPopup} transparent animationType="fade" onRequestClose={() => setShowDeleteConfirmPopup(false)}>
        <View style={styles.popupOverlay}>
          <View style={styles.popupCard}>
            <TouchableOpacity
              style={styles.popupCloseBtn}
              onPress={() => { setShowDeleteConfirmPopup(false); setPendingDeleteID(null); }}
              hitSlop={{ top: 10, bottom: 10, left: 10, right: 10 }}
            >
              <MaterialCommunityIcons name="close" size={18} color="#9ca3af" />
            </TouchableOpacity>
            <View style={styles.popupIconRow}>
              <View style={[styles.popupIconCircle, { backgroundColor: '#fef2f2' }]}>
                <MaterialCommunityIcons name="trash-can-outline" size={22} color="#ef4444" />
              </View>
            </View>
            <Text style={styles.popupTitle}>Delete Diagnosis?</Text>
            <Text style={styles.popupBody}>This diagnosis will be permanently deleted and cannot be recovered.</Text>
            <View style={styles.popupDivider} />
            <View style={styles.popupBtnRow}>
              <TouchableOpacity style={styles.popupDangerBtn} onPress={handleConfirmDelete}>
                <Text style={styles.popupDangerBtnText}>Delete</Text>
              </TouchableOpacity>
              <TouchableOpacity
                style={styles.popupOutlineBtn}
                onPress={() => { setShowDeleteConfirmPopup(false); setPendingDeleteID(null); }}
              >
                <Text style={styles.popupOutlineBtnText}>Cancel</Text>
              </TouchableOpacity>
            </View>
          </View>
        </View>
      </Modal>

      {/* ── Delete Success Popup ── */}
      <Modal visible={showDeleteSuccessPopup} transparent animationType="fade" onRequestClose={() => setShowDeleteSuccessPopup(false)}>
        <View style={styles.popupOverlay}>
          <View style={styles.popupCard}>
            <View style={styles.popupIconRow}>
              <View style={[styles.popupIconCircle, { backgroundColor: '#f3f4f6' }]}>
                <MaterialCommunityIcons name="trash-can-outline" size={22} color="#6b7280" />
              </View>
            </View>
            <Text style={styles.popupTitle}>Diagnosis Deleted</Text>
            <Text style={styles.popupBody}>The diagnosis has been removed successfully.</Text>
            <View style={styles.popupDivider} />
            <View style={styles.popupBtnRow}>
              <TouchableOpacity
                style={[styles.popupPrimaryBtn, { backgroundColor: '#c0392b' }]}
                onPress={() => setShowDeleteSuccessPopup(false)}
              >
                <Text style={styles.popupPrimaryBtnText}>Done</Text>
              </TouchableOpacity>
            </View>
          </View>
        </View>
      </Modal>

      {/* ── AI Insight Popup ── */}
      <Modal visible={!!insightPopup} transparent animationType="fade" onRequestClose={handleCloseInsightPopup}>
        <View style={styles.popupOverlay}>
          <View style={[styles.popupCard, { paddingBottom: 16 }]}>
            <View style={styles.insightPopupHeader}>
              <View style={[styles.popupIconCircle, { backgroundColor: '#ecfeff', marginRight: 10 }]}>
                <MaterialCommunityIcons
                  name={(insightPopup?.diagnoses?.length ?? 0) === 1 ? "lightbulb-outline" : "lightbulb-multiple-outline"}
                  size={18}
                  color="#0891b2"
                />
              </View>
              <View style={{ flex: 1 }}>
                <Text style={[styles.popupTitle, { textAlign: 'left' }]} numberOfLines={1}>
                  {(insightPopup?.diagnoses?.length ?? 0) === 1 ? 'Insights for Wellbeing' : 'Combined Insights'}
                </Text>
                <Text style={styles.insightSubtitle} numberOfLines={1}>
                  {insightPopup?.diagnoses?.map(d => d.category).join(' · ')}
                </Text>
              </View>
            </View>

            <View style={styles.popupDivider} />

            <ScrollView style={{ maxHeight: height * 0.38 }} showsVerticalScrollIndicator={false}>
              <View style={styles.insightBox}>
                {aiLoading ? (
                  <View style={{ alignItems: 'center', paddingVertical: 16, gap: 8 }}>
                    <ActivityIndicator size="small" color="#0891b2" />
                    <Text style={{ fontSize: 12, color: '#0891b2', fontWeight: '600' }}>Analyzing diagnosis...</Text>
                    {[85, 70, 80, 60].map((w, i) => (
                      <View key={i} style={{ height: 8, backgroundColor: '#a5f3fc', borderRadius: 4, opacity: 0.4, width: `${w}%` }} />
                    ))}
                  </View>
                ) : (
                  <InsightContent text={insightPopup?.text ?? ''} textStyle={styles.insightText} />
                )}
              </View>
            </ScrollView>

            <TouchableOpacity
              onPress={handleRegenerateInsight}
              disabled={aiLoading}
              style={[styles.regenerateRow, aiLoading && { opacity: 0.4 }]}
            >
              <MaterialCommunityIcons name="refresh" size={13} color="#0891b2" />
              <Text style={styles.regenerateText}>Regenerate</Text>
            </TouchableOpacity>

            <View style={styles.popupDivider} />
            <View style={styles.popupBtnRow}>
              <TouchableOpacity
                onPress={() => handleSaveInsight((insightPopup?.diagnoses?.length ?? 0) > 1)}
                disabled={saveLoading || aiLoading}
                style={[styles.popupPrimaryBtn, { flex: 1 }, (saveLoading || aiLoading) && { opacity: 0.5 }]}
              >
                {saveLoading
                  ? <ActivityIndicator size="small" color="#fff" />
                  : <Text style={styles.popupPrimaryBtnText}>
                      {(insightPopup?.diagnoses?.length ?? 0) > 1 ? 'Save All' : 'Save'}
                    </Text>
                }
              </TouchableOpacity>

              {(insightPopup?.diagnoses?.length ?? 0) > 1 && (
                <TouchableOpacity
                  onPress={() => handleSaveInsight(false)}
                  disabled={saveLoading || aiLoading}
                  style={[styles.popupOutlineBtn, { borderColor: '#7DBE8E' }, (saveLoading || aiLoading) && { opacity: 0.5 }]}
                >
                  <Text style={[styles.popupOutlineBtnText, { color: '#7DBE8E' }]}>Save Latest</Text>
                </TouchableOpacity>
              )}

              <TouchableOpacity onPress={handleCloseInsightPopup} style={styles.popupOutlineBtn}>
                <Text style={styles.popupOutlineBtnText}>Cancel</Text>
              </TouchableOpacity>
            </View>
          </View>
        </View>
      </Modal>
    </View>
  );
});

