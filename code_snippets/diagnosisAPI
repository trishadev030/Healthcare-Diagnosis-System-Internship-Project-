}) => {
  const diagnosisColors = getDiagnosisColor(diagnosis.diagnosisType);
  const isEditLoading   = editLoading === diagnosis.encryptedID;
  const isDeleteLoading = deleteLoading === diagnosis.encryptedID;
  const [insightExpanded, setInsightExpanded] = useState(false);

  return (
    <TouchableOpacity
      activeOpacity={selectMode ? 0.7 : 1}
      onPress={selectMode ? () => onToggleSelect(diagnosis.encryptedID) : undefined}
    >
      <Card style={[styles.diagnosisCard, isSelected && styles.diagnosisCardSelected]}>
        {isSelected && <View style={styles.selectedStrip} />}
        <Card.Content>
          <View style={styles.diagnosisHeader}>
            <View style={[styles.diagnosisTypeBadge, { backgroundColor: diagnosisColors.background }]}>
              <MaterialCommunityIcons name={getDiagnosisIcon(diagnosis.diagnosisType)} size={16} color={diagnosisColors.text} />
              <Text style={[styles.diagnosisTypeText, { color: diagnosisColors.text }]}>
                {diagnosis.diagnosisType?.charAt(0).toUpperCase() + diagnosis.diagnosisType?.slice(1)}
              </Text>
            </View>
            {selectMode && (
              <View style={[styles.selectCircle, isSelected && styles.selectCircleActive]}>
