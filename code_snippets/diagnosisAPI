const getDiagnosisIcon = (type: string): string => {
  switch (type?.toLowerCase()) {
    case 'principle': return 'heart-pulse';
    case 'primary':   return 'stethoscope';
    case 'secondary': return 'pill';
    case 'tertiary':  return 'clipboard-pulse';
    case 'surgical':  return 'needle';
    default:          return 'medical-bag';
  }
};

const getDiagnosisColor = (type: string): { background: string; text: string } => {
  switch (type?.toLowerCase()) {
    case 'principle': return { background: '#dbeafe', text: '#1e40af' };
    case 'primary':   return { background: '#f0fdf4', text: '#166534' };
    case 'secondary': return { background: '#fef9c3', text: '#854d0e' };
    case 'tertiary':  return { background: '#fae8ff', text: '#7e22ce' };
    case 'surgical':  return { background: '#fff7ed', text: '#c2410c' };
    default:          return { background: '#f3f4f6', text: '#374151' };
  }
};

const parseDate = (dateStr: string): number => {
  if (!dateStr) return 0;
  const parts = dateStr.split('/');
  if (parts.length === 3) {
    return new Date(parseInt(parts[2]), parseInt(parts[0]) - 1, parseInt(parts[1])).getTime();
  }
  const d = new Date(dateStr);
  return isNaN(d.getTime()) ? 0 : d.getTime();
};

const cleanText = (text: string): string =>
  text
    .replace(/\*\*(.*?)\*\*/g, '$1')
    .replace(/\*(.*?)\*/g, '$1')
    .replace(/#{1,6}\s/g, '')
    .trim();

// Parses insight text into structured bullet/text lines
const formatInsight = (text: string): { type: 'bullet' | 'text'; content: string }[] => {
  if (!text) return [];
  return text
    .split('\n')
    .map(line => line.trim())
    .filter(line => line.length > 0)
    .map(line => {
      if (/^[-•*]/.test(line)) {
        return { type: 'bullet' as const, content: line.replace(/^[-•*]\s*/, '').trim() };
      }
      return { type: 'text' as const, content: line };
    });
};

// Renders formatted insight lines with dash bullets and spacing
const InsightContent: React.FC<{ text: string; textStyle: any; bodyStyle?: any }> = ({ text, textStyle, bodyStyle }) => {
  const lines = formatInsight(text);
  return (
    <>
      {lines.map((item, i) =>
        item.type === 'bullet' ? (
          <View key={i} style={[styles.insightBulletRow, bodyStyle]}>
            <Text style={[textStyle, styles.insightBulletDash]}>{' - '}</Text>
            <Text style={[textStyle, styles.insightBulletText]}>{item.content}</Text>
          </View>
        ) : (
          <Text key={i} style={[textStyle, styles.insightPlainLine, bodyStyle]}>{item.content}</Text>
        )
      )}
    </>
  );
};

const FILTER_TYPES = ['Principle', 'Primary', 'Secondary', 'Tertiary', 'Surgical'];

const DIAGNOSIS_TYPE_MAP: Record<string, string> = {
  principle: '0',
  primary:   '1',
  secondary: '2',
  tertiary:  '3',
  surgical:  '4',
};

